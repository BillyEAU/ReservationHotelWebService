  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Setelah melakukan login, tambahkan token JWT (tanpa Bearer) yang telah didapatkan ke dalam kolom 'VALUE' yang telah disediakan!."
      }
    },
    "schemas": {
      "KamarResponse": {
        "type": "object",
        "properties": {
          "id_kamar": { "type": "integer", "example": 1 },
          "id_tipe_kamar": { "type": "integer", "example": 2 },
          "nomor_kamar": { "type": "string", "example": "12" },
          "status": { "type": "string", "example": "Tersedia" }
        }
      },
      "KamarInput": {
        "type": "object",
        "required": ["id_tipe_kamar", "nomor_kamar"],
        "properties": {
          "id_tipe_kamar": { "type": "integer", "description": "ID Tipe Kamar (Harus angka positif)", "example": 2 },
          "nomor_kamar": { "type": "string", "maxLength": 10, "description": "Tambahkan nomor dalam bentuk angka", "example": "12" },
          "status": { "type": "string", "enum": ["Tersedia", "Terisi", "Dipesan", "Pembersihan"], "default": "Tersedia", "example": "Tersedia" }
        }
      },
      "TipeKamarResponse": {
        "type": "object",
        "properties": {
          "id_tipe_kamar": { "type": "integer", "example": 1 },
          "nama_tipe": { "type": "string", "example": "Deluxe Room" },
          "harga": { "type": "number", "example": 750000 },
          "fasilitas": { "type": "string", "example": "AC, TV, Wifi, Bathtub, Breakfast" }
        }
      },
      "TipeKamarInput": {
        "type": "object",
        "required": ["nama_tipe", "harga"],
        "properties": {
