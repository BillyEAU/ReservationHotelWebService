{
  "openapi": "3.0.0",
  "info": {
    "title": "Reservasi API",
    "description": "API untuk reservasi hotel",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:2024/api",
      "description": "Local Server"
    }
  ],
  "tags": [
    {
      "name": "API Auth",
      "description": "Endpoint Autentikasi dan Login Karyawan"
    },
    {
      "name": "API Kamar",
      "description": "Endpoint Data Kamar"
    },
    {
      "name": "API Tipe Kamar",
      "description": "Endpoint Data Tipe Kamar"
    },
    {
      "name": "API Reservasi",
      "description": "Endpoint Data Reservasi Hotel"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["API Auth"],
        "summary": "Autentikasi Login Karyawan",
        "description": "Mengirimkan username dan password untuk mendapatkan token akses JWT.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string", "example": "resepsionis1" },
                  "password": { "type": "string", "format": "password", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login Berhasil!",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Login Berhasil!" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id_karyawan": { "type": "integer", "example": 1 },
                        "nama_karyawan": { "type": "string", "example": "Raditya Arya Wiguna" },
                        "username": { "type": "string", "example": "radit" },
                        "role": { "type": "string", "example": "Admin" },
                        "token": { "type": "string", "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Username dan password wajib diisi",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "error": { "type": "string", "example": "Username dan password wajib diisi" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Password Salah",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "error": { "type": "string", "example": "Password Salah" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Data Karyawan tidak ditemukan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": false },
                    "error": { "type": "string", "example": "Data Karyawan tidak ditemukan" }
                  }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      }
    },
    "/kamar": {
      "get": {
        "tags": ["API Kamar"],
        "summary": "Mengambil semua data kamar",
        "description": "Menampilkan list semua kamar hotel beserta detail id_tipe_kamar.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Data Berhasil Ditemukan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Data Berhasil Ditemukan" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/KamarResponse" }
                    }
                  }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/404NotFound" },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      },
      "post": {
        "tags": ["API Kamar"],
        "summary": "Menambahkan data kamar baru",
        "description": "Membuat record kamar baru ke dalam database. Status default jika tidak diisi adalah 'Tersedia'.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/KamarInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Data Berhasil Ditambahkan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Data Berhasil Ditambahkan" },
                    "data": { "$ref": "#/components/schemas/KamarResponse" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/400BadRequest" },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      }
    },
    "/kamar/{id}": {
      "get": {
        "tags": ["API Kamar"],
        "summary": "Menampilkan data kamar berdasarkan ID Kamar",
        "security": [{ "bearerAuth": [] }],
