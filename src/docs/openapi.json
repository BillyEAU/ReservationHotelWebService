          }
        ],
        "responses": {
          "200": {
            "description": "Data Berhasil Ditemukan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Data Berhasil Ditemukan" },
                    "data": { "$ref": "#/components/schemas/KamarResponse" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/400BadRequest" },
          "404": { "$ref": "#/components/responses/404NotFound" },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      },
      "put": {
        "tags": ["API Kamar"],
        "summary": "Mengupdate data kamar berdasarkan ID Kamar",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Masukkan ID dari kamar yang ingin diubah :",
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/KamarInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data Berhasil Diupdate",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Data Berhasil Diupdate" },
                    "data": { "$ref": "#/components/schemas/KamarResponse" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/400BadRequest" },
          "404": { "$ref": "#/components/responses/404NotFound" },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      },
      "delete": {
        "tags": ["API Kamar"],
        "summary": "Menghapus data kamar berdasarkan ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Masukkan ID dari kamar yang ingin dihapus :",
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Data Kamar Berhasil Dihapus",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Data Kamar Berhasil Dihapus" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id_kamar": { "type": "integer", "example": 1 },
                        "nomor_kamar": { "type": "string", "example": "12" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/400BadRequest" },
          "404": { "$ref": "#/components/responses/404NotFound" },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      }
    },
    "/kamar/status/{status}": {
      "get": {
        "tags": ["API Kamar"],
        "summary": "Mengecek ketersediaan kamar berdasarkan status",
        "description": "Mencari list kamar berdasarkan parameter status (Tersedia, Terisi, Dipesan, dan Pembersihan)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "status",
            "in": "path",
            "required": true,
            "description": "Status Kamar",
            "schema": {
              "type": "string",
              "enum": ["Tersedia", "Terisi", "Dipesan", "Pembersihan"],
              "example": "Tersedia"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil mengambil data kamar berdasarkan status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id_kamar": { "type": "integer", "example": 1 },
                          "id_tipe_kamar": { "type": "integer", "example": 2 },
                          "nomor_kamar": { "type": "string", "example": "12" },
                          "status": { "type": "string", "example": "Tersedia" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      }
    },
