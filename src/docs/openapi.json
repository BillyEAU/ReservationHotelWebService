    "/reservasi": {
      "get": {
        "tags": ["API Reservasi"],
        "summary": "Mengambil semua data reservasi hotel",
        "description": "Menampilkan seluruh list transaksi reservasi hotel.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Data Berhasil Ditemukan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Data Berhasil Ditemukan" },
